{
  "expo": {
    "name": "Vocal Spectrum",
    "slug": "vocal-spectrum-schedule",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d1b2a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vocalspectrum.schedule"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d1b2a"
      },
      "package": "com.vocalspectrum.schedule"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": []
  }
}
